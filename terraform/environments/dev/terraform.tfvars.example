# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored, so real
# values (your IP, key name, email) never reach the repository.
#
#   cp terraform.tfvars.example terraform.tfvars

aws_region   = "us-east-1"
project_name = "claude-first-project"

# --- Network ---
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]
az_count            = 2

# --- Instances ---
instance_type    = "t3.micro"
root_volume_size = 20

# SSH access. Set key_name to an existing EC2 key pair and allowed_ssh_cidr to
# YOUR address as a /32. Find your address with:  curl -s https://checkip.amazonaws.com
# Leave both null to manage instances only through SSM Session Manager.
# key_name         = "my-keypair"
# allowed_ssh_cidr = "203.0.113.42/32"

# --- Auto Scaling ---
min_size         = 1
desired_capacity = 2
max_size         = 4
scale_out_cpu    = 70
scale_in_cpu     = 30
critical_cpu     = 80

# --- Monitoring ---
metrics_namespace = "ClaudeFirstProject"
# alarm_email     = "you@example.com"   # confirm the SNS subscription email after apply

# --- CI/CD (optional) ---
# Set these once the GitHub OIDC provider exists in your account.
# enable_github_oidc       = true
# github_oidc_provider_arn = "arn:aws:iam::111122223333:oidc-provider/token.actions.githubusercontent.com"
# github_repository        = "sandeepvardhanboyina/Claude_Devops_Project_01"
# state_bucket_arn         = "arn:aws:s3:::claude-first-project-tfstate-111122223333"
# state_lock_table_arn     = "arn:aws:dynamodb:us-east-1:111122223333:table/claude-first-project-tflock"
